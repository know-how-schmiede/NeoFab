#!/usr/bin/env bash
#
# Reset the password of an existing NeoFab admin user.
# Intended as an emergency maintenance helper for physically controlled servers.

set -euo pipefail

prompt() {
  local var="$1" label="$2" default="$3" value
  read -r -p "$label [$default]: " value || true
  printf -v "$var" "%s" "${value:-$default}"
}

prompt APP_USER "System user running NeoFab" "neofab"
prompt APP_HOME "Install directory" "/home/${APP_USER}/projects/neofab"
prompt DEFAULT_PASSWORD "Password to set" "ChangePass"

VENV_PYTHON="$APP_HOME/.venv/bin/python"
WORK_DIR="$APP_HOME/neofab"

if [[ ! -x "$VENV_PYTHON" ]]; then
  echo "Virtualenv Python not found at $VENV_PYTHON." >&2
  exit 1
fi

if [[ ! -f "$WORK_DIR/app.py" ]]; then
  echo "Could not find app.py in $WORK_DIR. Check your install path." >&2
  exit 1
fi

if [[ ! -f "$WORK_DIR/neofab.db" ]]; then
  echo "Could not find database at $WORK_DIR/neofab.db." >&2
  exit 1
fi

run_python() {
  if [[ ${EUID:-$(id -u)} -eq 0 ]] && id -u "$APP_USER" >/dev/null 2>&1; then
    sudo -u "$APP_USER" bash -lc "cd \"$WORK_DIR\" && \"$VENV_PYTHON\" -"
  else
    cd "$WORK_DIR"
    "$VENV_PYTHON" -
  fi
}

echo "==> Reading admin users from $WORK_DIR/neofab.db ..."

run_python <<PY
from app import app
from models import db, User
import sys

default_password = ${DEFAULT_PASSWORD@Q}

try:
    tty = open("/dev/tty", "r", encoding="utf-8")
except OSError:
    tty = sys.stdin

def prompt_input(prompt):
    print(prompt, end="", flush=True)
    line = tty.readline()
    if line == "":
        raise SystemExit("No interactive input available.")
    return line.rstrip("\n")

with app.app_context():
    admins = (
        User.query
        .filter_by(role="admin")
        .order_by(User.id.asc())
        .all()
    )

    if not admins:
        raise SystemExit("No admin users found.")

    print()
    print("Admin users:")
    for index, user in enumerate(admins, start=1):
        name_parts = [user.first_name or "", user.last_name or ""]
        display_name = " ".join(part for part in name_parts if part).strip()
        suffix = f" ({display_name})" if display_name else ""
        print(f"  {index}) ID {user.id}: {user.email}{suffix}")
    print()

    raw_choice = prompt_input("Select admin user number to reset (empty = abort): ").strip()
    if not raw_choice:
        raise SystemExit("Aborted.")

    try:
        choice = int(raw_choice)
    except ValueError:
        raise SystemExit("Invalid selection.")

    if choice < 1 or choice > len(admins):
        raise SystemExit("Invalid selection.")

    selected = admins[choice - 1]
    print()
    print(f"Selected: {selected.email}")
    confirm = prompt_input(f"Set password to '{default_password}'? Type YES to continue: ").strip()
    if confirm != "YES":
        raise SystemExit("Aborted.")

    selected.set_password(default_password)
    db.session.commit()
    print(f"Password for {selected.email} was reset to '{default_password}'.")
PY
